# ansible/group_vars/all.yml.example
# Copy this file to all.yml and fill in real values.
# all.yml is git-ignored and must NEVER be committed.
#
# Service host addresses (postgres_host, redis_host, minio_host, etc.) are
# resolved automatically from inventory groups at play time — do NOT set them
# here.  See ansible/tasks/set_service_hosts.yml for the resolution logic.

# ── Project paths ────────────────────────────────────────────
lethe_root: "{{ ansible_env.HOME }}/lethe"

# ── PostgreSQL ───────────────────────────────────────────────
postgres_user: lethe
postgres_password: "CHANGE_ME"
postgres_db: lethe_db
postgres_port: 5432

# ── Redis ────────────────────────────────────────────────────
redis_port: 6379
# Set a strong password when Redis is exposed on a network interface.
redis_password: "CHANGE_ME_REDIS_PASSWORD"

# ── MinIO ────────────────────────────────────────────────────
minio_version: "RELEASE.2024-06-13T22-53-53Z"
minio_access_key: "CHANGE_ME_ACCESS"
minio_secret_key: "CHANGE_ME_SECRET"
minio_port: 9000
minio_console_port: 9001
minio_bucket: lethe-imports

# ── Load Balancer ─────────────────────────────────────────────
# Virtual IP managed by Keepalived — the public-facing entry point.
lb_virtual_ip: "CHANGE_ME_VIP_IP"
lb_virtual_interface: "eth0"
# Keepalived VRRP auth password (max 8 chars).
keepalived_auth_pass: "CHANGE_ME"
haproxy_stats_password: "CHANGE_ME_HAPROXY_STATS"
# Port HAProxy listens on for incoming HTTP traffic.
haproxy_frontend_port: 80
# Port HAProxy exposes native Prometheus metrics on (localhost only).
# Must match haproxy_prometheus_port in prometheus.yml.j2 — change both together.
haproxy_prometheus_port: 8405

# ── Backend ──────────────────────────────────────────────────
backend_port: 3001
encryption_key: "CHANGE_ME_32_BYTES_EXACTLY______"   # must be exactly 32 UTF-8 bytes
internal_webhook_secret: "CHANGE_ME_INTERNAL_SECRET"
export_api_key: "CHANGE_ME_EXPORT_API_KEY"

# ── Importer ─────────────────────────────────────────────────
# Politeness delay (seconds) between individual post requests in the importer.
importer_post_delay_seconds: 2

# ── Monitoring ───────────────────────────────────────────────
grafana_admin_password: "CHANGE_ME_GRAFANA_PASSWORD"
prometheus_port: 9090
loki_port: 3100
# Grafana uses port 3030 by default to avoid collision with Next.js (port 3000)
# in single-server deployments.
grafana_port: 3030
node_exporter_port: 9100
promtail_port: 9080
prometheus_version: "2.51.2"
loki_version: "3.0.0"
promtail_version: "3.0.0"
node_exporter_version: "1.7.0"

# ── Logging ──────────────────────────────────────────────────
# Set to 'info' or 'warn' to reduce verbosity in production.
log_level: "debug"

# ── Node.js ──────────────────────────────────────────────────
node_version: "20"

# ── Python ───────────────────────────────────────────────────
python_version: "python3"

# ── Git Repository ───────────────────────────────────────────────────
git_repo_url: "git@github.com:strongestgreekgodvsweakestturkiyefemboy/lethe.git"
