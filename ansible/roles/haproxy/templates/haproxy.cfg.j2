#---------------------------------------------------------------------
# HAProxy configuration — generated by Ansible
#---------------------------------------------------------------------

global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    maxconn 50000

defaults
    log     global
    mode    http
    option  httplog
    option  dontlognull
    option  forwardfor
    option  http-server-close
    timeout connect  5s
    timeout client   60s
    timeout server   60s
    errorfile 400 /etc/haproxy/errors/400.http
    errorfile 403 /etc/haproxy/errors/403.http
    errorfile 408 /etc/haproxy/errors/408.http
    errorfile 500 /etc/haproxy/errors/500.http
    errorfile 502 /etc/haproxy/errors/502.http
    errorfile 503 /etc/haproxy/errors/503.http
    errorfile 504 /etc/haproxy/errors/504.http

#---------------------------------------------------------------------
# Stats page
#---------------------------------------------------------------------
frontend stats
    bind *:8404
    stats enable
    stats uri /stats
    stats refresh 10s
    stats auth admin:{{ haproxy_stats_password }}
    stats hide-version

#---------------------------------------------------------------------
# Prometheus metrics endpoint (HAProxy native exporter, 2.0.14+)
# Scraped by Prometheus on the monitoring host.
# Bound to localhost only — not reachable from the public internet.
#---------------------------------------------------------------------
frontend prometheus_metrics
    bind 127.0.0.1:{{ haproxy_prometheus_port | default(8405) }}
    http-request use-service prometheus-exporter if { path /metrics }
    no log

#---------------------------------------------------------------------
# Public HTTP frontend
#---------------------------------------------------------------------
frontend http_in
    bind *:{{ haproxy_frontend_port }}
    default_backend app_servers

    # Health-check endpoint answered directly by HAProxy
    acl is_health path /haproxy-health
    http-request return status 200 content-type text/plain string "OK\n" if is_health

#---------------------------------------------------------------------
# App backend — forward to the local Nginx caching proxy (port 8080).
# Nginx in turn routes /api/* to the backend server and / to the frontend.
# To scale horizontally, add more [lb] hosts and list each Nginx here.
# Health check uses /lb-health which Nginx answers directly — this
# decouples LB health from backend availability so a backend restart
# never marks the server DOWN and produces empty (0-byte) responses.
#---------------------------------------------------------------------
backend app_servers
    balance roundrobin
    option httpchk GET /lb-health
    http-check expect status 200
    server nginx_local 127.0.0.1:8080 check inter 5s rise 2 fall 3
