# /etc/keepalived/keepalived.conf — generated by Ansible

# Track HAProxy: demote to BACKUP immediately if HAProxy goes down.
vrrp_script chk_haproxy {
    script "killall -0 haproxy"
    interval 2
    weight  -20
    fall    2
    rise    2
}

vrrp_instance LETHE_LB {
    state            {{ keepalived_state }}
    interface        {{ lb_virtual_interface }}
    virtual_router_id {{ keepalived_vrrp_id }}
    priority         {{ keepalived_priority }}
    advert_int       1

    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }

    virtual_ipaddress {
        {{ lb_virtual_ip }}/24
    }

    track_script {
        chk_haproxy
    }
}
