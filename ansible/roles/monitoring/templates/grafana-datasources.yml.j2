# /etc/grafana/provisioning/datasources/lethe.yml — generated by Ansible
apiVersion: 1

datasources:
  - name: Prometheus
    type: prometheus
    access: proxy
    url: http://localhost:{{ prometheus_port }}
    isDefault: true
    editable: false

  - name: Loki
    type: loki
    access: proxy
    url: http://localhost:{{ loki_port }}
    editable: false
