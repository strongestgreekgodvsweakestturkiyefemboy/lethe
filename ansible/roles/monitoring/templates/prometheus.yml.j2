# /etc/prometheus/prometheus.yml — generated by Ansible
global:
  scrape_interval:     15s
  evaluation_interval: 15s
  external_labels:
    cluster: lethe

alerting:
  alertmanagers: []

rule_files: []

scrape_configs:
  # ── Node Exporter on every host ───────────────────────────
  - job_name: node
    static_configs:
{% for host in groups['lethe'] | default([]) %}
      - targets:
          - "{{ hostvars[host]['ansible_host'] | default(host) }}:{{ node_exporter_port }}"
        labels:
          instance: "{{ host }}"
{% endfor %}

  # ── HAProxy native Prometheus exporter ────────────────────
  - job_name: haproxy
    metrics_path: /metrics
    static_configs:
{% for host in groups['lb'] | default([]) %}
      - targets:
          - "{{ hostvars[host]['ansible_host'] | default(host) }}:{{ haproxy_prometheus_port | default(8405) }}"
        labels:
          instance: "{{ host }}"
{% endfor %}

  # ── Lethe backend /metrics (if exposed) ───────────────────
  - job_name: lethe_backend
    metrics_path: /metrics
    static_configs:
{% for host in groups['app'] | default([]) %}
      - targets:
          - "{{ hostvars[host]['ansible_host'] | default(host) }}:{{ backend_port }}"
        labels:
          instance: "{{ host }}"
{% endfor %}

  # ── Prometheus self-scrape ────────────────────────────────
  - job_name: prometheus
    static_configs:
      - targets: ["localhost:{{ prometheus_port }}"]
