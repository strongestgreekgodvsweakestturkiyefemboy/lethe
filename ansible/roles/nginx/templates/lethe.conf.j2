# /etc/nginx/sites-available/lethe
# Caching reverse proxy for Lethe.
# Deployed on the dedicated cache-proxy server (lb tier).
# HAProxy listens on port 80 and forwards here (port 8080).
# Proxies:
#   /lb-health       → answered locally by Nginx (HAProxy liveness probe)
#   /api/*           → backend (Express, {{ backend_host }}:{{ backend_port }})
#   /healthz         → backend health check (passthrough to Express)
#   /api/v1/imports/*/stream  → backend SSE (buffering disabled)
#   /                → Next.js frontend ({{ frontend_host }}:3000) with static-asset cache

proxy_cache_path /var/cache/nginx/lethe
  levels=1:2
  keys_zone=lethe_cache:10m
  max_size=1g
  inactive=60m
  use_temp_path=off;

upstream lethe_backend {
    server {{ backend_host }}:{{ backend_port }};
    keepalive 32;
}

upstream lethe_frontend {
    server {{ frontend_host }}:3000;
    keepalive 32;
}

server {
    listen 8080;
    server_name _;

    # ── Gzip compression ─────────────────────────────────────
    gzip on;
    gzip_types text/plain text/css application/json application/javascript
               text/xml application/xml application/xml+rss text/javascript;
    gzip_min_length 1000;

    # ── SSE: import progress stream ───────────────────────────
    # Must come before the generic /api/ block.
    location ~ ^/api/v1/imports/[^/]+/stream {
        proxy_pass         http://lethe_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   Connection        '';

        # SSE requires chunked transfer — disable all buffering.
        proxy_buffering    off;
        proxy_cache        off;
        proxy_read_timeout 3600s;
        chunked_transfer_encoding on;

        # CORS — needed when EventSource connects from a different origin
        # (e.g. direct port-3000 access during development).
        proxy_hide_header Access-Control-Allow-Origin;
        add_header        'Access-Control-Allow-Origin' '*' always;
    }

    # ── Backend API ───────────────────────────────────────────
    location /api/ {
        # ── CORS ──────────────────────────────────────────────
        # Answer OPTIONS preflight immediately — no need to hit the backend.
        # Using an if-block for method dispatch is safe here because it
        # only executes a return and no proxy directives.
        if ($request_method = 'OPTIONS') {
            add_header 'Access-Control-Allow-Origin'  '*' always;
            add_header 'Access-Control-Allow-Methods' 'GET, HEAD, POST, PUT, PATCH, DELETE, OPTIONS' always;
            # Only browser-facing headers needed here; x-api-key is server-to-server only.
            add_header 'Access-Control-Allow-Headers' 'Content-Type, Authorization' always;
            add_header 'Access-Control-Max-Age'       86400 always;
            return 204;
        }

        # Strip the upstream CORS headers so nginx's copies are the sole
        # source of truth and never appear twice (duplicate CORS headers
        # cause browsers to reject the response).
        proxy_hide_header Access-Control-Allow-Origin;
        proxy_hide_header Access-Control-Allow-Methods;
        proxy_hide_header Access-Control-Allow-Headers;

        # The `always` flag ensures CORS headers appear even on
        # nginx-generated error responses (502, 504, …) where the backend
        # never had a chance to set them — which is the root cause of the
        # NS_ERROR_NET_RESET failures seen in cross-origin test scenarios.
        # Wildcard origin is safe here because this API uses token-based auth
        # (Authorization header / API keys), not cookies — credentials are
        # never implicitly attached to cross-origin requests.
        add_header 'Access-Control-Allow-Origin'  '*' always;
        add_header 'Access-Control-Allow-Methods' 'GET, HEAD, POST, PUT, PATCH, DELETE, OPTIONS' always;
        add_header 'Access-Control-Allow-Headers' 'Content-Type, Authorization' always;

        proxy_pass         http://lethe_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   Connection        '';
        proxy_read_timeout 60s;

        # Do not cache API mutations; allow short-lived cache for GET reads.
        proxy_cache        lethe_cache;
        proxy_cache_methods GET HEAD;
        proxy_cache_valid  200 10s;
        proxy_cache_bypass $http_cache_control;
        add_header         X-Cache-Status $upstream_cache_status always;
    }

    # ── HAProxy liveness probe (answered by Nginx directly) ──────
    # HAProxy polls this to decide whether to route traffic here.
    # Keeping the probe local means a backend restart never marks the
    # LB server as DOWN — backend unavailability surfaces as a proper
    # 502 instead of an empty TCP close (shown as blank/0 B in browsers).
    location = /lb-health {
        access_log   off;
        default_type text/plain;
        return 200   "OK\n";
    }

    # ── Backend health check ──────────────────────────────────
    location /healthz {
        proxy_pass         http://lethe_backend;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_cache        off;
    }

    # ── Next.js static assets (aggressive cache) ──────────────
    location /_next/static/ {
        proxy_pass         http://lethe_frontend;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;

        proxy_cache        lethe_cache;
        proxy_cache_valid  200 1d;
        proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
        add_header         Cache-Control "public, max-age=86400, immutable";
        add_header         X-Cache-Status $upstream_cache_status;
    }

    # ── Frontend (Next.js) ────────────────────────────────────
    location / {
        proxy_pass         http://lethe_frontend;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_read_timeout 60s;

        proxy_cache        lethe_cache;
        proxy_cache_valid  200 1m;
        proxy_cache_bypass $http_pragma $http_authorization;
        add_header         X-Cache-Status $upstream_cache_status;
    }
}
